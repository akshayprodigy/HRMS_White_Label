# Copy to .env and adjust as needed

# App
ENVIRONMENT=local
CORS_ORIGINS=http://localhost:5173

# Auth / JWT
# IMPORTANT: Set this to a strong random value in production.
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_DAYS=30

# Refresh cookie
# In production behind HTTPS, set REFRESH_COOKIE_SECURE=true
REFRESH_COOKIE_NAME=refresh_token
REFRESH_COOKIE_SECURE=false
REFRESH_COOKIE_SAMESITE=lax
REFRESH_COOKIE_PATH=/

# Database (MariaDB)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=unitederp
DB_USER=unitederp
DB_PASSWORD=unitederp

# Used by Alembic + SQLAlchemy
DATABASE_URL=mysql+pymysql://unitederp:unitederp@localhost:3306/unitederp

# One-time bootstrap (optional): create an initial admin user
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_ROLE=admin
