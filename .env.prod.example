# Production example (.env)
# Copy to .env on your VPS and set real secrets.

# Public domain (used by Caddyfile)
DOMAIN=erp.example.com

# App
ENVIRONMENT=production
# Since frontend + API are served on the same domain in production, CORS can be your domain.
CORS_ORIGINS=https://erp.example.com

# Auth / JWT
# IMPORTANT: set a strong random value (32+ chars)
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_DAYS=30

# Refresh cookie (production)
REFRESH_COOKIE_NAME=refresh_token
REFRESH_COOKIE_SECURE=true
REFRESH_COOKIE_SAMESITE=lax
REFRESH_COOKIE_PATH=/

# Database (MariaDB)
DB_NAME=unitederp
DB_USER=unitederp
DB_PASSWORD=
DB_ROOT_PASSWORD=

# Optional tuning
WEB_CONCURRENCY=2
GUNICORN_TIMEOUT=60

# One-time bootstrap (run via make prod-bootstrap-admin)
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_ROLE=admin
