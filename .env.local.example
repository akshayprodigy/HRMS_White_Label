# Local (Docker Desktop) environment defaults.
# Copy to .env.local and edit if you need non-defaults.
#   cp .env.local.example .env.local
#
# .env.local is gitignored (via `.env.*` in the root .gitignore).
# Do NOT commit .env.local or real secrets.

# ---- Database (MariaDB 11) -----------------------------------------------
# Values are picked up by both the db container's MARIADB_* init vars
# and the backend's pydantic-settings Settings class.
DB_NAME=erp_local
DB_USER=erp_user
DB_PASSWORD=erp_password
DB_ROOT_PASSWORD=root_password
MARIADB_DB=erp_local
MARIADB_USER=erp_user
MARIADB_PASSWORD=erp_password
MARIADB_PORT=3306
# NOTE: MARIADB_SERVER is set to "db" by docker-compose.local.yml — do
# NOT override here.

# ---- App --------------------------------------------------------------
PROJECT_NAME=ERP United (Local)
LOG_LEVEL=INFO

# ---- Security ----------------------------------------------------------
# 32+ chars. Local-only value; NEVER reuse in production.
SECRET_KEY=local-dev-secret-not-for-production-32chars-min
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=11520
REFRESH_TOKEN_EXPIRE_MINUTES=43200

# ---- CORS --------------------------------------------------------------
# JSON list of origins allowed by the FastAPI CORS middleware.
# 4180 = nginx frontend, 4001 = direct API (for Swagger + tests).
BACKEND_CORS_ORIGINS=["http://localhost:4180","http://localhost:4001","http://localhost:5173"]

# ---- Email / SMS providers --------------------------------------------
# Leave BOTH sections empty locally. The notifications service falls
# back to LogEmailProvider + LogSMSProvider — no real sends, ever.
# Uncomment and fill in only if you need to test real delivery.
#
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=no-reply@localhost
# SMTP_STARTTLS=1
#
# MSG91_AUTH_KEY=
# MSG91_SENDER_ID=ERPAPP

# ---- Local admin bootstrap --------------------------------------------
# Used by scripts/seed_local.py to create the admin login.
# Change LOCAL_ADMIN_PASSWORD before running the seed if you don't want
# the default. Local-only credential — never seed this in prod.
LOCAL_ADMIN_EMAIL=admin@example.com
LOCAL_ADMIN_PASSWORD=LocalAdmin!2026
